# =============================================================================
# MODELO — copie para .env e preencha (nunca commite o .env)
#   copy .env.example .env
#   notepad .env
# Depois:  . .\scripts\load-env.ps1   e   .\mvnw.cmd spring-boot:run
# Manual completo: README.MD (Caminho B)
# =============================================================================

# --- Integração iFood (Caminho B) ---
IFOOD_MOCK_ENABLED=false
IFOOD_POLLING_ENABLED=true
IFOOD_POLLING_INTERVAL_MS=15000

# Developer → Meus aplicativos → Client ID
IFOOD_CLIENT_ID=

# Developer → Meus aplicativos → Client Secret
IFOOD_CLIENT_SECRET=

# Obtido no README Passo 3 (OAuth). String longa, uma linha, sem aspas.
IFOOD_REFRESH_TOKEN=

# Developer → Lojas de teste → UUID da loja (não é o Client ID)
IFOOD_MERCHANT_ID=

# --- MySQL local ---
DB_USERNAME=root
DB_PASSWORD=12345

# --- Opcional ---
# IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br

# =============================================================================
# Caminho A — só testar tela sem iFood (comente o bloco acima e use):
# IFOOD_MOCK_ENABLED=true
# IFOOD_POLLING_ENABLED=false
# =============================================================================
